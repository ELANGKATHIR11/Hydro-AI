# Hydro-AI Mapathon Edition Configuration

# Target Tamil Nadu District (e.g., Kancheepuram, Tiruvallur, Madurai, Cuddalore)
DISTRICT=Kancheepuram

# Database settings: Fallback to local SQLite for FOSS local-first setup
DATABASE_URL=sqlite:///hydro_ai_mapathon.db

# Ingestion configuration
DATA_DIR=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
DERIVED_DATA_DIR=data/derived
OUTPUT_DIR=outputs

# Space/National Geospatial policy settings
COMPLIANCE_MODE=STRICT
ALLOW_SYNTHETIC_DATA=FALSE
